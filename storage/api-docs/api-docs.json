                                    "$ref": "#/components/schemas/Artesano"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "No encontrado"
                    }
                }
            }
        },
        "/api/articulos": {
            "get": {
                "tags": [
                    "Articulos"
                ],
                "summary": "Listar artículos (público, sin autenticación)",
                "description": "Devuelve todos los artículos con su categoría, artesano, tienda e imágenes. Acepta filtros opcionales por query string; si no se envía ninguno se devuelven todos.",
                "operationId": "021362b92b70d8c24f566bb0db7178d5",
                "parameters": [
                    {
                        "name": "categoria",
                        "in": "query",
                        "description": "ID de la categoría",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "artesano",
                        "in": "query",
                        "description": "ID del artesano",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "tienda",
                        "in": "query",
                        "description": "ID de la tienda",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "color",
                        "in": "query",
                        "description": "Color exacto",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "bordado",
                        "in": "query",
                        "description": "Tipo de bordado",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "tela",
                        "in": "query",
                        "description": "Tipo de tela",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "region",
                        "in": "query",
                        "description": "Región de origen",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Listado de artículos",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/Articulo"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/articulos/{id}": {
            "get": {
                "tags": [
                    "Articulos"
                ],
                "summary": "Ver un artículo (público, sin autenticación)",
                "operationId": "53ebb83e59d006abd1bd488176d98899",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID del artículo",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Artículo encontrado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/Articulo"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Artículo no encontrado"
                    }
                }
            },
            "put": {
                "tags": [
                    "Articulos"
                ],
                "summary": "Actualizar un artículo (requiere permiso editarArticulos)",
                "description": "Update the specified resource in storage.",
                "operationId": "8b012fffca1a2f25e37727c1097c0471",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "nombre",
                                    "precio",
                                    "stock"
                                ],
                                "properties": {
                                    "nombre": {
                                        "type": "string",
                                        "example": "Huipil bordado"
                                    },
                                    "descripcion": {
                                        "type": "string",
                                        "example": "Bordado a mano"
                                    },
                                    "precio": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 1250
                                    },
                                    "stock": {
                                        "type": "integer",
                                        "example": 12
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Artículo actualizado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Articulo"
                                }
                            }
                        }
                    },
                    "403": {
                        "description": "Sin permiso"
                    },
                    "422": {
                        "description": "Datos inválidos"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "Articulos"
                ],
                "summary": "Eliminar un artículo (requiere permiso eliminarArticulos)",
                "description": "Remove the specified resource from storage.",
                "operationId": "de4809e8ad8eea751584f66ed2aab554",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Artículo eliminado"
                    },
                    "403": {
                        "description": "Sin permiso"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Iniciar sesión y obtener un token JWT",
                "description": "Generar un JWT a partir de credenciales.",
                "operationId": "a3b306d14572d1f4bd6c064b3233e7b8",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "test@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "password"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Autenticación correcta",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "access_token": {
                                            "type": "string"
                                        },
                                        "token_type": {
                                            "type": "string",
                                            "example": "bearer"
                                        },
                                        "expires_in": {
                                            "type": "integer",
                                            "example": 3600
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Credenciales inválidas"
                    }
                }
            }
        },
        "/api/categorias": {
            "get": {
                "tags": [
                    "Categorias"
                ],
                "summary": "Listar categorías (público)",
                "operationId": "66bfb3e0bf7747700be142ec5329dfae",
