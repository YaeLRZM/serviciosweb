{
    "openapi": "3.0.0",
    "info": {
        "title": "API Servicios Web - Artesanías",
        "description": "API REST para el catálogo de artículos artesanales, tiendas, categorías y artesanos.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000",
            "description": "Servidor local"
        }
    ],
    "paths": {
        "/api/artesanos": {
            "get": {
                "tags": [
                    "Artesanos"
                ],
                "summary": "Listar artesanos (público)",
                "operationId": "079e10370d2bf3552563f9c8dee8b503",
                "responses": {
                    "200": {
                        "description": "Listado de artesanos",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/Artesano"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/artesanos/{id}": {
            "get": {
                "tags": [
                    "Artesanos"
                ],
                "summary": "Ver un artesano (público)",
                "operationId": "d631149ad3a4a08139f7f972c0f191d1",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Artesano encontrado",
