                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Categoria"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "No encontrada"
                    }
                }
            }
        },
        "/chatbot": {
            "post": {
                "tags": [
                    "Chatbot"
                ],
                "summary": "Asistente conversacional de artículos (público)",
                "description": "Recibe un mensaje del usuario y responde consultando el catálogo de artículos. Usa el formato del driver web de BotMan. Detecta color, región y tipo de bordado en el texto.",
                "operationId": "8c9ed65b69cc7edc4b0b81e004e3327f",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "driver",
                                    "message"
                                ],
                                "properties": {
                                    "driver": {
                                        "type": "string",
                                        "example": "web"
                                    },
                                    "message": {
                                        "type": "string",
                                        "example": "busco algo rojo de oaxaca"
                                    },
                                    "userId": {
                                        "type": "string",
                                        "example": "1"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Respuesta(s) del asistente",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "integer",
                                            "example": 200
                                        },
                                        "messages": {
                                            "type": "array",
                                            "items": {
                                                "properties": {
                                                    "type": {
                                                        "type": "string",
                                                        "example": "text"
                                                    },
                                                    "text": {
                                                        "type": "string",
                                                        "example": "Huipil bordado — rojo, Oaxaca (Artesanías del Sur)"
                                                    },
                                                    "attachment": {
                                                        "type": "string",
                                                        "example": null,
                                                        "nullable": true
                                                    },
                                                    "additionalParameters": {
                                                        "type": "array",
                                                        "items": {
                                                            "type": "string"
                                                        }
                                                    }
                                                },
                                                "type": "object"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
