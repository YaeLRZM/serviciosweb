    "components": {
        "schemas": {
            "LoginRequest": {
                "required": [
                    "email",
                    "password"
                ],
                "properties": {
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "usuario@correo.com"
                    },
                    "password": {
                        "type": "string",
                        "format": "password",
                        "example": "secret123"
                    }
                },
                "type": "object"
            },
            "UserUpsertRequest": {
                "required": [
                    "name",
                    "email",
                    "password"
                ],
                "properties": {
                    "name": {
                        "type": "string",
                        "example": "Admin"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "admin@correo.com"
                    },
                    "password": {
                        "type": "string",
                        "format": "password",
                        "example": "secret123"
                    }
                },
                "type": "object"
            },
            "ArticuloUpsertRequest": {
                "required": [
                    "nombre",
                    "precio",
                    "stock"
                ],
                "properties": {
                    "nombre": {
                        "type": "string",
                        "example": "Laptop"
                    },
                    "descripcion": {
                        "type": "string",
                        "example": "Equipo portátil de alto rendimiento",
                        "nullable": true
                    },
                    "precio": {
                        "type": "number",
                        "format": "float",
                        "example": 999.99
                    },
                    "stock": {
                        "type": "integer",
                        "example": 10
                    }
                },
                "type": "object"
            },
            "ResenaUpsertRequest": {
                "required": [
                    "titulo",
                    "puntuacion"
                ],
                "properties": {
                    "titulo": {
                        "type": "string",
                        "example": "Excelente compra"
                    },
                    "contenido": {
                        "type": "string",
                        "example": "El producto llegó en perfectas condiciones.",
                        "nullable": true
                    },
                    "puntuacion": {
                        "type": "integer",
                        "example": 5
                    }
                },
                "type": "object"
            },
            "CompraUpsertRequest": {
                "required": [
                    "user_id",
                    "articulo_id",
                    "cantidad",
                    "precio_unitario"
                ],
                "properties": {
                    "user_id": {
                        "type": "integer",
                        "example": 1
                    },
                    "articulo_id": {
                        "type": "integer",
                        "example": 1
                    },
                    "cantidad": {
                        "type": "integer",
                        "example": 2
                    },
                    "precio_unitario": {
                        "type": "number",
                        "format": "float",
                        "example": 499.99
                    }
                },
                "type": "object"
            },
            "TokenResponse": {
                "properties": {
                    "access_token": {
                        "type": "string",
                        "example": "eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9..."
                    },
                    "token_type": {
                        "type": "string",
                        "example": "Bearer"
                    },
                    "expires_in": {
                        "type": "integer",
                        "example": 3600
                    },
                    "user": {
                        "properties": {
                            "id": {
                                "type": "integer",
                                "example": 1
                            },
                            "name": {
                                "type": "string",
                                "example": "Admin"
                            },
                            "email": {
                                "type": "string",
                                "format": "email",
                                "example": "admin@correo.com"
                            },
                            "email_verified_at": {
                                "type": "string",
                                "format": "date-time",
                                "example": "2026-07-06T12:00:00Z",
                                "nullable": true
                            },
                            "created_at": {
                                "type": "string",
                                "format": "date-time",
                                "nullable": true
                            },
                            "updated_at": {
                                "type": "string",
                                "format": "date-time",
                                "nullable": true
                            }
                        },
                        "type": "object"
                    }
                },
                "type": "object"
            },
            "User": {
                "required": [
                    "name",
                    "email"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Admin"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "admin@correo.com"
                    },
                    "email_verified_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2026-07-06T12:00:00Z",
                        "nullable": true
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
